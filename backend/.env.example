# ── Backend environment configuration ──────────────────────────────
# Copy the relevant values into the project ROOT .env file
# (the pool in src/config/database.js reads DB_* from there).
# JWT_* / PORT / CORS_ORIGIN are read by the API layer.

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=procurement_auditor

# Auth — MUST set a long random JWT_SECRET in production
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=8h

# API server
PORT=5000
CORS_ORIGIN=http://localhost:5173
